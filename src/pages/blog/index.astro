---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';

const posts = await getCollection('blog');
// Sort by date descending
posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Layout 
    title="Blog | Dr. Neha Mehta" 
    description="Read our latest articles on relationships, mental health, and wellness."
>
    <div class="w-full px-3 py-16 sm:px-6 sm:py-24 max-w-7xl mx-auto">
        <header class="text-center mb-16">
            <h1 class="text-4xl font-black sm:text-5xl mb-4">Latest Articles</h1>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto">Insights and advice to help you navigate relationships and mental wellness.</p>
        </header>

        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
                <article class="bg-base-100 rounded-2xl shadow-sm border border-base-200 overflow-hidden hover:shadow-md transition-shadow">
                    <div class="p-6">
                        <div class="flex items-center gap-2 mb-4">
                            {post.data.tags.slice(0, 2).map((tag) => (
                                <span class="bg-primary/10 text-primary text-xs font-bold px-2 py-1 rounded-full uppercase tracking-wider">{tag}</span>
                            ))}
                        </div>
                        <h2 class="text-2xl font-bold mb-3 leading-tight">
                            <a href={`/blog/${post.slug}`} class="hover:text-primary transition-colors">
                                {post.data.title}
                            </a>
                        </h2>
                        <p class="text-gray-600 mb-6 line-clamp-3">
                            {post.data.description}
                        </p>
                        <div class="flex items-center justify-between text-sm text-gray-500 font-medium mt-auto">
                            <span>{post.data.author}</span>
                            <time datetime={post.data.publishDate.toISOString()}>
                                {post.data.publishDate.toLocaleDateString('en-US', {
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric',
                                })}
                            </time>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</Layout>
